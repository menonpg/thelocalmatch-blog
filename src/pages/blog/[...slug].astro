---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { calculateReadingTime, formatReadingTime } from '../../utils/readingTime';
import { generateBlogPostSchema } from '../../utils/schema';

export async function getStaticPaths() {
  const now = new Date();
  const posts = await getCollection('blog');
  const publishedPosts = posts.filter(post => {
    if (post.data.draft) return false;
    if (post.data.publishDate) {
      if (new Date(post.data.publishDate) > now) return false;
    }
    return true;
  });
  return publishedPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const readingTime = calculateReadingTime(post.body);
const postUrl = `https://blog.thelocalmatch.com/blog/${post.slug}`;
const canonicalUrl = post.data.canonical || postUrl;
const schema = generateBlogPostSchema(post, postUrl);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <link slot="head" rel="canonical" href={canonicalUrl} />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  {post.data.faqItems && post.data.faqItems.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": post.data.faqItems.map((item: {question: string, answer: string}) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })} />
  )}

  <!-- Reading progress bar -->
  <div class="reading-progress" role="progressbar" aria-label="Reading progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
    <div class="reading-progress-bar"></div>
  </div>

  <!-- Scroll to top -->
  <button id="scroll-to-top" class="scroll-to-top" aria-label="Scroll to top">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
      <path d="M10 4L10 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <path d="M5 8L10 3L15 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'Blog', href: '/blog' },
    { label: post.data.title }
  ]} />

  <article class="post" aria-labelledby="post-title">
    <header>
      <h1 id="post-title">{post.data.title}</h1>
      <div class="meta">
        <time datetime={post.data.date}>Published {post.data.date}</time>
        {post.data.updated && (
          <>
            <span class="sep" aria-hidden="true">·</span>
            <time datetime={post.data.updated}>Updated {post.data.updated}</time>
          </>
        )}
        <span class="sep" aria-hidden="true">·</span>
        <span class="reading-time">{formatReadingTime(readingTime)}</span>
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="content">
      <Content />
    </div>

    <aside class="cta-block">
      <h2>Ready to bring professional matchmaking to your city?</h2>
      <p>
        The Local Match Co. is expanding — one city, one trusted operator at a time.
        Built on 25 years of proven methodology from Pittsburgh's premier matchmaking service.
      </p>
      <a href="https://thelocalmatch.com/#invest" class="cta-btn" target="_blank" rel="noopener">
        Explore Franchise Opportunities →
      </a>
    </aside>

    <footer class="post-footer">
      <a href="/blog">← Back to all posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post h1 { margin-bottom: 0.75rem; }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.875rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .sep { opacity: 0.5; }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: rgba(139, 26, 26, 0.15);
    color: var(--accent);
    border-radius: 1rem;
    border: 1px solid rgba(139, 26, 26, 0.3);
  }

  .content { margin-bottom: 3rem; }
  .content :global(h2) { margin-top: 2.5rem; }
  .content :global(h3) { margin-top: 2rem; }
  .content :global(p) { margin-bottom: 1.5rem; line-height: 1.8; }
  .content :global(img) { max-width: 100%; border-radius: 0.5rem; margin: 2rem 0; }
  .content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--muted);
  }
  .content :global(ul), .content :global(ol) { margin-bottom: 1.5rem; }
  .content :global(strong) { color: var(--fg); }

  .cta-block {
    margin: 3rem 0 2rem;
    padding: 2rem;
    background: rgba(139, 26, 26, 0.08);
    border: 1px solid rgba(139, 26, 26, 0.3);
    border-radius: 0.75rem;
    text-align: center;
  }

  .cta-block h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--fg);
  }

  .cta-block p {
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--accent);
    color: var(--cream);
    text-decoration: none;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: background 0.2s;
  }

  .cta-btn:hover { background: var(--accent-light); }

  .post-footer {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .post-footer a { color: var(--muted); text-decoration: none; }
  .post-footer a:hover { color: var(--accent); }

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: transparent;
    z-index: 1000;
    pointer-events: none;
  }

  .reading-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #8B1A1A, #c0392b);
    transition: width 0.1s ease-out;
  }

  .scroll-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 3rem;
    height: 3rem;
    background: var(--accent);
    border: none;
    border-radius: 50%;
    color: var(--cream);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: all 0.3s ease;
    z-index: 999;
  }

  .scroll-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .scroll-to-top:hover { background: var(--accent-light); }
</style>

<script>
  // Reading progress
  function updateProgress() {
    const article = document.querySelector('.post');
    const bar = document.querySelector('.reading-progress-bar') as HTMLElement;
    if (!article || !bar) return;
    const articleTop = (article as HTMLElement).offsetTop;
    const articleHeight = (article as HTMLElement).offsetHeight;
    const windowHeight = window.innerHeight;
    const scrollTop = window.scrollY;
    const scrollStart = articleTop - windowHeight / 4;
    const scrollEnd = articleTop + articleHeight - windowHeight;
    const scrollRange = scrollEnd - scrollStart;
    if (scrollTop < scrollStart) { bar.style.width = '0%'; }
    else if (scrollTop > scrollEnd) { bar.style.width = '100%'; }
    else { bar.style.width = `${((scrollTop - scrollStart) / scrollRange) * 100}%`; }
  }

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => { updateProgress(); ticking = false; });
      ticking = true;
    }
  }, { passive: true });

  // Scroll to top
  const btn = document.getElementById('scroll-to-top');
  window.addEventListener('scroll', () => {
    btn?.classList.toggle('visible', window.scrollY > 300);
  }, { passive: true });
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
